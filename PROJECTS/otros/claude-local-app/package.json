{
  "name": "gemini-local-app",
  "type": "module",
  "version": "1.0.0",
  "description": "Gemini AI Local - Herramienta de IA para Arquitectura de Sistemas",
  "main": "electron/main-simple.mjs",
  "scripts": {
    "dev": "astro dev --port 3000",
    "start": "astro dev --port 3000",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "electron": "electron electron/main-simple.mjs",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:dmg": "npm run build && electron-builder --mac dmg"
  },
  "dependencies": {
    "@astrojs/node": "^8.3.4",
    "@astrojs/react": "^3.0.0",
    "@astrojs/tailwind": "^5.1.0",
    "@google/generative-ai": "^0.21.0",
    "@monaco-editor/react": "^4.6.0",
    "astro": "^4.5.0",
    "body-parser": "^2.2.2",
    "clsx": "^2.1.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^0.344.0",
    "monaco-editor": "^0.46.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "sqlite": "^4.2.0",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^2.2.0",
    "tailwindcss": "^3.4.0",
    "uuid": "^9.0.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.8",
    "concurrently": "^8.2.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.0",
    "typescript": "^5.3.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.retarget.gemini-local",
    "productName": "Gemini AI Local",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "data/**/*",
      "node_modules/sqlite3/**/*",
      "node_modules/sqlite/**/*",
      "node_modules/@google/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns"
    },
    "dmg": {
      "sign": false
    }
  }
}
