{
  "version": "1.1",
  "description": "MCP Supervisor configuration for distributed subagent orchestration. Asistente Retarget — desarrollado por Sistemas - Retarget ❤️.",
  "identity": {
    "name": "Asistente Retarget",
    "developed_by": "Sistemas - Retarget ❤️",
    "signature": "— Asistente Retarget · desarrollado por Sistemas - Retarget ❤️",
    "first_contact_greeting": "Hola, soy el Asistente de Retarget desarrollado por Sistemas - Retarget ❤️. ¿Con quién tengo el gusto?",
    "ask_user_name_if_missing": true,
    "remember_user_name_per_session": true,
    "self_description": "No soy solo un chat: coordino al equipo, redacto los mensajes exactos para que copies y pegues a Luis o quien corresponda, tomo screenshots y dejo respaldo de cada investigación con su fuente.",
    "communication_style": {
      "be_human": true,
      "ask_before_blocking": true,
      "no_silent_failures": true,
      "always_offer_next_step": true
    }
  },
  "auth": {
    "enabled": true,
    "strategy": "email-domain-allowlist",
    "domain_allowlist": ["@retarget.cl"],
    "team_contract": "contracts/team.json",
    "on_unauthorized": "Lo siento, este asistente está disponible solo para correos @retarget.cl. Si crees que es un error, escríbele a Luis."
  },
  "supervisor": {
    "name": "quality-gate-supervisor",
    "role": "orchestrator",
    "responsibilities": [
      "coordinate subagents",
      "manage workflows",
      "enforce contracts",
      "aggregate results",
      "route blockers to the right human collaborator with a copy-paste-ready message",
      "enforce research evidence protocol (link + screenshot + backup + reasoning)"
    ]
  },
  "research_protocol": {
    "description": "Toda tarea investigativa devuelve fuente, screenshot y respaldo. Sin esto, la respuesta NO se da por completa.",
    "required_outputs": ["source_link", "screenshot", "backup", "reasoning_trace"],
    "evidence_root": "evidence/${project}/${view}/",
    "applies_to_subagents": ["reconnaissance", "qa-validator", "seo-auditor", "content-writer", "doc-reporter"],
    "audience_rules": {
      "jefe-2": "desconfiado — toda afirmación con fuente + screenshot + alternativa descartada",
      "periodista": "exige certeza — cada dato con (fuente: url); distinguir hecho vs opinión; sin fuente => marcar 'sin verificar'"
    }
  },
  "collaboration_protocol": {
    "description": "Cuando el avance se bloquea, NO callar. Identificar al colaborador correcto, redactar el mensaje exacto y entregárselo al usuario para copiar/pegar.",
    "team_contract": "contracts/team.json",
    "before_marking_blocked": [
      "intentar resolver yo mismo",
      "buscar en lessons-kb",
      "preguntar al usuario una sola pregunta clara",
      "si persiste: identificar al miembro del equipo (luis | jefe-2 | periodista) y emitir mensaje listo para enviar"
    ],
    "output_when_blocked": {
      "blocker_summary": "1 línea",
      "target_member": "luis | jefe-2 | periodista",
      "ready_to_send_message": "texto completo usando el message_template del miembro",
      "evidence_attached": ["screenshot_path", "source_links"]
    }
  },
  "subagents": [
    {
      "id": "reconnaissance",
      "name": "Reconnaissance Subagent",
      "model": "claude-opus",
      "role": "Analyze origin sites and extract specifications",
      "skills": [
        "site-analysis",
        "asset-discovery",
        "content-mapping",
        "platform-detect"
      ],
      "tools": [
        "screenshot",
        "lessons-search"
      ],
      "context_cache": {
        "enabled": true,
        "ttl_minutes": 60,
        "key": "reconnaissance-context"
      },
      "max_iterations": 3,
      "timeout_seconds": 300,
      "workspace_folders": {
        "input": "projects/${project}/reconnaissance/",
        "output": "projects/${project}/specs/"
      }
    },
    {
      "id": "designer",
      "name": "Designer Subagent",
      "model": "claude-opus",
      "role": "Create and manage visual design, layouts, and UI components",
      "skills": [
        "visual-design",
        "component-design",
        "color-theory",
        "typography",
        "responsive-layouts"
      ],
      "tools": [
        "write",
        "edit",
        "screenshot",
        "visual-diff",
        "lessons-search"
      ],
      "context_cache": {
        "enabled": true,
        "ttl_minutes": 90,
        "key": "designer-context"
      },
      "max_iterations": 5,
      "timeout_seconds": 600,
      "workspace_folders": {
        "input": "projects/${project}/content/designer/",
        "output": "projects/${project}/src/components/"
      }
    },
    {
      "id": "content-writer",
      "name": "Content Writer Subagent",
      "model": "claude-sonnet",
      "role": "Create and manage content, copy, and text assets",
      "skills": [
        "copywriting",
        "content-strategy",
        "seo-copy",
        "multilingual-content",
        "brand-voice"
      ],
      "tools": [
        "write",
        "edit",
        "lessons-search"
      ],
      "context_cache": {
        "enabled": true,
        "ttl_minutes": 120,
        "key": "content-writer-context"
      },
      "max_iterations": 3,
      "timeout_seconds": 400,
      "workspace_folders": {
        "input": "projects/${project}/content/writer/",
        "output": "projects/${project}/content/published/"
      }
    },
    {
      "id": "layout-builder",
      "name": "Layout Builder Subagent",
      "model": "claude-opus",
      "role": "Build and fix CSS/HTML layouts from designer specs",
      "skills": [
        "css-fix",
        "responsive-design",
        "visual-alignment",
        "component-build"
      ],
      "tools": [
        "edit",
        "write",
        "screenshot",
        "lessons-search"
      ],
      "context_cache": {
        "enabled": true,
        "ttl_minutes": 60,
        "key": "layout-builder-context"
      },
      "max_iterations": 5,
      "timeout_seconds": 600,
      "workspace_folders": {
        "input": "projects/${project}/specs/",
        "output": "projects/${project}/src/components/"
      }
    },
    {
      "id": "content-loader",
      "name": "Content Loader Subagent",
      "model": "claude-opus",
      "role": "Download and manage assets from designer/content folders",
      "skills": [
        "asset-download",
        "cdn-management",
        "image-optimization",
        "metadata-extract"
      ],
      "tools": [
        "bash",
        "write",
        "lessons-search"
      ],
      "context_cache": {
        "enabled": true,
        "ttl_minutes": 120,
        "key": "content-loader-context"
      },
      "max_iterations": 2,
      "timeout_seconds": 900,
      "workspace_folders": {
        "input": "projects/${project}/content/designer/",
        "output": "projects/${project}/public/media/"
      }
    },
    {
      "id": "qa-validator",
      "name": "QA Validator Subagent",
      "model": "claude-opus",
      "role": "Validate visually and audit",
      "skills": [
        "screenshot-capture",
        "visual-diff",
        "lighthouse-audit",
        "accessibility-check"
      ],
      "tools": [
        "screenshot",
        "visual-diff",
        "validate",
        "lessons-search"
      ],
      "context_cache": {
        "enabled": true,
        "ttl_minutes": 30,
        "key": "qa-validator-context"
      },
      "max_iterations": 4,
      "timeout_seconds": 300,
      "workspace_folders": {
        "input": "projects/${project}/src/",
        "output": "projects/${project}/reports/qa/"
      }
    },
    {
      "id": "deployment",
      "name": "Deployment Subagent",
      "model": "claude-opus",
      "role": "Manage git and deployments",
      "skills": [
        "git-ops",
        "railway-deploy",
        "smoke-test",
        "rollback"
      ],
      "tools": [
        "bash",
        "logs",
        "railway-logs",
        "lessons-search"
      ],
      "context_cache": {
        "enabled": true,
        "ttl_minutes": 60,
        "key": "deployment-context"
      },
      "max_iterations": 3,
      "timeout_seconds": 600,
      "workspace_folders": {
        "input": "projects/${project}/",
        "output": "projects/${project}/.deploy/"
      }
    },
    {
      "id": "doc-reporter",
      "name": "Documentation, Reporting & Process-Learning Subagent",
      "model": "claude-sonnet",
      "role": "Three responsibilities, in this order: (1) silently journal every meaningful event during the session; (2) at session close, generate one self-contained markdown report with embedded images; (3) analyze the journal to debug the workflow itself and queue concrete improvement patches for other subagents (skills, configs, contracts).",
      "skills": [
        "session-report",
        "journal-event",
        "publish-report",
        "image-compress",
        "debug-and-learn"
      ],
      "tools": [
        "bash",
        "write",
        "lessons-log",
        "lessons-search"
      ],
      "context_cache": {
        "enabled": true,
        "ttl_minutes": 60,
        "key": "doc-reporter-context"
      },
      "context_blocks_required": [
        "contracts/${project}.json",
        "policies/GOOGLE_POLICIES.md",
        "mcp-subagents-config.json"
      ],
      "rules": {
        "publish_only_at_session_close": true,
        "silent_during_session": true,
        "self_contained_assets": true,
        "respects_owner_voice": true,
        "feedback_patches_require_owner_approval": true,
        "auto_log_lessons_only_when_high_confidence": true,
        "max_token_budget_percent_of_session": 5
      },
      "outputs": {
        "report_md": "reports/${project}/${date}/REPORT.md",
        "debug_report_json": "reports/${project}/${date}/debug-report.json",
        "feedback_queue": "feedback-queue/${project}/pending.jsonl",
        "lessons_logged": "lessons/lessons.jsonl"
      },
      "max_iterations": 1,
      "timeout_seconds": 600,
      "workspace_folders": {
        "input": "projects/${project}/",
        "output": "reports/${project}/"
      }
    },
    {
      "id": "seo-auditor",
      "name": "SEO & Performance Auditor Subagent",
      "model": "claude-opus",
      "role": "Audit deployed sites against Google policies (Core Web Vitals, SEO, A11y, Security) and produce a remediation plan",
      "policies_ref": "policies/GOOGLE_POLICIES.md",
      "skills": [
        "google-compliance",
        "lighthouse-audit",
        "structured-data-validate",
        "accessibility-check",
        "security-headers-check",
        "performance-budget-check"
      ],
      "tools": [
        "bash",
        "screenshot",
        "validate",
        "logs",
        "lessons-search"
      ],
      "context_cache": {
        "enabled": true,
        "ttl_minutes": 60,
        "key": "seo-auditor-context"
      },
      "context_blocks_required": [
        "policies/GOOGLE_POLICIES.md",
        "contracts/${project}.json"
      ],
      "max_iterations": 1,
      "timeout_seconds": 600,
      "workspace_folders": {
        "input": "projects/${project}/",
        "output": "projects/${project}/reports/seo/"
      }
    }
  ],
  "workflows": [
    {
      "name": "clone-site-complete",
      "description": "Full site cloning workflow from analysis to deployment",
      "steps": [
        {
          "step": 1,
          "subagent": "reconnaissance",
          "skill": "site-analysis",
          "input": {
            "url": "${origin_url}",
            "depth": 2,
            "extract_specs": true
          },
          "output": "site-recon.json",
          "required": true
        },
        {
          "step": 2,
          "subagent": "content-loader",
          "skill": "asset-download",
          "input": {
            "urls": "${site-recon.cdn_urls}",
            "target_dir": "public/media",
            "optimize": true
          },
          "output": "assets-manifest.json",
          "required": true
        },
        {
          "step": 3,
          "subagent": "layout-builder",
          "skill": "component-build",
          "input": {
            "sections": "${site-recon.landings}",
            "brand": "${site-recon.brand}",
            "reference_images": "${evidence_dir}"
          },
          "output": "src/components/sections/*.tsx",
          "required": true,
          "loop": {
            "until": "all_sections_done",
            "max_iterations": 8
          }
        },
        {
          "step": 4,
          "subagent": "qa-validator",
          "skill": "visual-diff",
          "input": {
            "sections": "${all_sections}",
            "tolerance_percent": 2.0
          },
          "output": "validation-report.json",
          "required": true,
          "loop": {
            "until": "all_pass",
            "max_iterations": 4,
            "feedback_to": "layout-builder"
          }
        },
        {
          "step": 5,
          "subagent": "deployment",
          "skill": "git-ops",
          "input": {
            "action": "commit",
            "message": "feat: clone site complete",
            "files": "${all_modified_files}"
          },
          "output": "commit-hash",
          "required": true
        },
        {
          "step": 6,
          "subagent": "deployment",
          "skill": "railway-deploy",
          "input": {
            "branch": "main",
            "auto_push": true
          },
          "output": "deploy-status",
          "required": true
        }
      ]
    },
    {
      "name": "google-compliance-audit",
      "description": "Audit a deployed URL against Google policies and emit a remediation plan handed to layout-builder",
      "trigger": "pre-deploy-gate or post-deploy or on-demand",
      "steps": [
        {
          "step": 1,
          "subagent": "seo-auditor",
          "skill": "google-compliance",
          "input": {
            "project": "${project}",
            "url": "${deploy_url}",
            "level": "${audit_level}"
          },
          "output": "audit-report.json",
          "required": true
        },
        {
          "step": 2,
          "condition": "audit-report.verdict == FAIL",
          "subagent": "layout-builder",
          "skill": "css-fix",
          "input": {
            "remediation_plan": "${audit-report.remediation_plan}",
            "constraints": "${contract.constraints}"
          },
          "output": "modified-files",
          "loop": {
            "until": "audit-report.verdict == PASS",
            "max_iterations": 4,
            "feedback_to": "seo-auditor"
          }
        },
        {
          "step": 3,
          "condition": "audit-report.verdict == PASS",
          "subagent": "deployment",
          "skill": "git-ops",
          "input": {
            "action": "commit",
            "message": "perf+seo: apply Google compliance remediations"
          }
        }
      ],
      "blocking": true,
      "policies_ref": "policies/GOOGLE_POLICIES.md"
    },
    {
      "name": "iterate-section",
      "description": "Iterate a single section until visual diff is acceptable",
      "steps": [
        {
          "step": 1,
          "subagent": "qa-validator",
          "skill": "screenshot-capture",
          "input": {
            "section": "${section_id}",
            "deploy_url": "${deploy_url}"
          },
          "output": "actual.png"
        },
        {
          "step": 2,
          "subagent": "qa-validator",
          "skill": "visual-diff",
          "input": {
            "section": "${section_id}",
            "tolerance_percent": 2.0
          },
          "output": "diff-report.json",
          "loop": {
            "condition": "diff_percent > tolerance",
            "feedback_to": "layout-builder",
            "max_iterations": 4
          }
        },
        {
          "step": 3,
          "subagent": "layout-builder",
          "skill": "css-fix",
          "input": {
            "section": "${section_id}",
            "issue": "${diff_report.issues}",
            "constraint": "${contract.constraints}"
          },
          "output": "modified-files"
        },
        {
          "step": 4,
          "subagent": "deployment",
          "skill": "git-ops",
          "input": {
            "action": "commit",
            "message": "fix(${section_id}): adjust layout based on visual diff"
          },
          "output": "commit-hash"
        }
      ]
    }
  ],
  "context_caching": {
    "enabled": true,
    "strategy": "per-subagent",
    "cache_blocks": [
      {
        "name": "methodology",
        "content": "METODOLOGIA.md",
        "ttl_minutes": 120,
        "shared": true
      },
      {
        "name": "antipatterns",
        "content": "ANTIPATTERNS.md",
        "ttl_minutes": 120,
        "shared": true
      },
      {
        "name": "project-contract",
        "content": "contracts/${project}.json",
        "ttl_minutes": 60,
        "shared": true
      },
      {
        "name": "lessons-kb",
        "content": "lessons/lessons.jsonl",
        "ttl_minutes": 30,
        "shared": true
      },
      {
        "name": "mcp-enterprise-analysis",
        "content": "docs/MCP_ENTERPRISE_ANALYSIS.md",
        "ttl_minutes": 180,
        "shared": true
      },
      {
        "name": "prompt-engineering-guide",
        "content": "docs/guia-ejecutiva-prompt-engineering.md",
        "ttl_minutes": 180,
        "shared": true
      },
      {
        "name": "anthropic-operators",
        "content": "docs/prompt-engineering-8-operadores-anthropic.md",
        "ttl_minutes": 180,
        "shared": true
      }
    ]
  },
  "error_handling": {
    "strategy": "escalate-and-retry",
    "max_retries": 3,
    "retry_delay_seconds": 5,
    "escalation": {
      "after_retries": 3,
      "notify": "supervisor",
      "action": "pause-workflow"
    }
  },
  "monitoring": {
    "enabled": true,
    "metrics": [
      "subagent-execution-time",
      "success-rate",
      "error-rate",
      "context-cache-hit-rate",
      "token-usage-per-subagent"
    ],
    "logging": {
      "level": "info",
      "format": "json",
      "destination": "logs/subagents.jsonl"
    }
  },
  "security": {
    "contract_enforcement": true,
    "validate_actions": true,
    "allowed_tools_per_subagent": {
      "reconnaissance": ["screenshot", "lessons-search"],
      "layout-builder": ["edit", "write", "screenshot", "lessons-search"],
      "content-loader": ["bash", "write", "lessons-search"],
      "qa-validator": ["screenshot", "visual-diff", "validate", "lessons-search"],
      "deployment": ["bash", "logs", "railway-logs", "lessons-search"],
      "seo-auditor": ["bash", "screenshot", "validate", "logs", "lessons-search"],
      "doc-reporter": ["bash", "write", "lessons-search"]
    }
  },
  "session_lifecycle": {
    "on_session_start": {
      "description": "Each subagent loads applied feedback patches from previous sessions before starting",
      "steps": [
        {
          "action": "load_applied_feedback",
          "source": "feedback-queue/${project}/applied.jsonl",
          "applies_to": "all-subagents"
        },
        {
          "action": "load_pending_lessons",
          "source": "lessons/lessons.jsonl",
          "filter": "learned_by == doc-reporter AND confidence == high",
          "applies_to": "all-subagents"
        }
      ]
    },
    "on_event": {
      "subagent": "doc-reporter",
      "skill": "journal-event",
      "silent": true,
      "events_tracked": [
        "iteration_done",
        "section_done",
        "audit_run",
        "commit",
        "deploy",
        "issue",
        "lesson_logged",
        "tool_failure",
        "stagnation_detected",
        "subagent_handoff",
        "cache_miss",
        "constraint_violation_attempt"
      ]
    },
    "on_session_close": {
      "description": "Three-stage close: publish report, debug the process, queue improvements",
      "stages": [
        {
          "stage": 1,
          "subagent": "doc-reporter",
          "skill": "publish-report",
          "blocking": true,
          "produces": "reports/${project}/${date}/REPORT.md"
        },
        {
          "stage": 2,
          "subagent": "doc-reporter",
          "skill": "debug-and-learn",
          "blocking": true,
          "produces": [
            "reports/${project}/${date}/debug-report.json",
            "feedback-queue/${project}/pending.jsonl"
          ],
          "auto_logs_lessons_when": "confidence == high AND seen_in >= 2 sessions"
        },
        {
          "stage": 3,
          "action": "notify_owner",
          "channels": ["inbox", "report_url"],
          "blocking": false
        }
      ]
    },
    "feedback_loop": {
      "description": "How improvement patches flow from doc-reporter to other subagents",
      "flow": [
        "doc-reporter:debug-and-learn writes patches to feedback-queue/pending.jsonl",
        "owner runs /inbox to review",
        "owner runs /approve <patch-id> -> MCP applies patch and moves to applied.jsonl",
        "owner runs /reject <patch-id> 'reason' -> moves to rejected.jsonl",
        "next session_start: all subagents load applied.jsonl",
        "doc-reporter measures whether anomaly recurs -> bumps confidence up/down"
      ],
      "auto_apply_when": "patch.confidence == high AND patch.target IN (skill_files | context_blocks) AND patch.risk == low",
      "never_auto_apply": ["mcp-supervisor source code", "Cargo.toml", "package.json"]
    }
  }
}
